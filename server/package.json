    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "overrides": {
    "esbuild": "^0.25.12",
    "expr-eval": "2.0.2",
    "uuid": "^14.0.0"
